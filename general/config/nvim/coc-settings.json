{
  "languageserver": {
    "golang": {
      "command": "gopls",
      "initializationOptions": {
        "usePlaceholders": false,
        "completeUnimported": true,
        "static_check": true,
        "hoverKind": "FullDocumentation"
      },
      "rootPatterns": ["go.mod", ".vim/", ".git/", ".hg/"],
      "filetypes": ["go"]
    }
  },

  "yaml.schemas": {
      "kubernetes": "/*.yaml"
  }

}

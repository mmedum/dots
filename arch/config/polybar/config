;:set syn=dosini

[global/wm]
margin-top = 5
margin-bottom = 2

[colors]
darkgray = #928374
orange = #fb4934
white = #d1d1d1
gray = #585858
black = #090909
red = #c795ae
blue = #95aec7
yellow = #c7ae95
green = #aec795
background = #282828
background-alt = #32302f
foreground = #a89984
foreground-alt = #55
primary = #1f222d
secondary = #FF6200
alert = #bd2c40

[bar/top]
bottom = false
monitor = ${env:MONITOR}
override-redirect = false
wm-restack = i3
width = 100%
height = 25
offset-x = 0
offset-y = 0

enable-ipc = true

padding-left = 0
padding-right = 0

module-margin-right = 1
module-margin-left = 0

modules-left = i3 xwindow
modules-center = date
modules-right = volume wlan battery

background = ${colors.background}
foreground = ${colors.foreground}

underline-size = 1
underline-color = ${colors.gray}

tray-detached = false
tray-position = right
tray-offset-x = 0
tray-offset-y = 0
tray-padding = 0
tray-transparent = false
tray-scale = 1.0

font-0 = SourceCodeProMedium:size=12;0
font-1 = FontAwesome5Free:style=Solid:pixelsize=12
font-2 = SourceCodeProMedium:weight=bold:size=12;0
font-3 = FontAwesome5Brands:style=Solid:pixelsize=12

[module/xwindow]
type = internal/xwindow
label = %title%
format-underline = ${colors.gray}
label-maxlen = 30

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
enable-click = false
enable-scroll = false
strip-wsnumbers = true

ws-icon-0 = 1:; ’äĀ
ws-icon-1 = 2:; ’äĪ
ws-icon-2 = 3:; ’ē©
ws-icon-3 = 4:; ’åś
ws-icon-4 = 5:; ’äĀ
ws-icon-5 = 6:; ’äĀ
ws-icon-6 = 7:; ’äĀ
ws-icon-7 = 8:; ’äĀ
ws-icon-8 = 9:; ’äĀ
ws-icon-9 = 10:; ’äĀ
ws-icon-default = ’äĀ

label-mode-padding = 2
label-mode-foreground = ${colors.foreground}
label-mode-background = ${colors.background}

label-focused-padding = 1
label-focused-background = ${colors.gray}

label-unfocused-padding = 1
label-visible-padding = 1

label-urgent-padding = 1
label-urgent-foreground = ${colors.red}

[module/wlan]
type = internal/network
interface = wlan0
interval = 3.0

format-connected-padding = 1
format-disconnected-padding = 1

format-connected = <label-connected>
format-connected-underline = ${colors.green}
format-disconnected-underline = ${colors.gray}

label-connected =’ć½ %essid%
label-disconnected = ’ć½
label-disconnected-foreground = ${colors.gray}

[module/eth]
type = internal/network
interface = enp0s31f6
interval = 3.0

format-connected-padding = 1
format-disconnected-padding = 1

format-connected-underline = ${colors.green}
format-disconnected-underline = ${colors.gray}

label-connected = ’ć║ 
label-disconnected = ’ć║
label-disconnected-foreground = ${colors.gray}

[module/date]
type = internal/date
date = ’ü│ %A %d %b ’ĆŚ %H:%M
interval = 5
format-underline = ${colors.gray}
format-foreground = ${colors.foreground}
format-padding = 1

[module/volume]
type = internal/alsa

format-volume = <label-volume>

label-volume = ’Ć© %percentage%
label-volume-foreground = ${colors.foreground}

label-muted = ’Ć”
label-muted-foreground = ${colors.gray}

[module/battery]
type = internal/battery
battery = BAT0
adapter = AC
time-format = %H:%M

format-charging = <animation-charging> <label-charging>
format-charging-underline = ${colors.green}
format-charging-padding = 1

label-charging = %time%
label-discharging = %time%
label-full =  ’ēĆ 

format-discharging = <ramp-capacity> <label-discharging>
format-discharging-underline = ${colors.yellow}
format-discharging-padding = 1

format-full-underline = ${self.format-charging-underline}
format-full-overline = ${self.format-charging-underline}
format-full-padding = 1

ramp-capacity-0 = ’ēä
ramp-capacity-1 = ’ēā
ramp-capacity-2 = ’ēé
ramp-capacity-3 = ’ēü
ramp-capacity-4 = ’ēĆ

animation-charging-0 = ’ēä
animation-charging-1 = ’ēā
animation-charging-2 = ’ēé
animation-charging-3 = ’ēü
animation-charging-4 = ’ēĆ
animation-charging-foreground = ${colors.foreground}
animation-charging-framerate = 500

; vim:ft=dosini

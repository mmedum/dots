;:set syn=dosini

[global/wm]
margin-top = 5
margin-bottom = 5


[colors]
white = #d1d1d1
gray = #585858
red = #c795ae
yellow = #c7ae95
green = #aec795
background = #99090909

[bar/top]
bottom = false
monitor = ${env:MONITOR}
override-redirect = false
wm-restack = i3
width = 100%
height = 16

enable-ipc = true

padding-left = 0
padding-right = 1

module-margin-right = 1
module-margin-left = 0

modules-left = i3 xwindow
modules-center = date
modules-right = volume wlan battery

background = ${colors.background}
foreground = ${colors.white}

underline-size = 1
underline-color = ${colors.white}

tray-detached = false
tray-transparent = true
tray-position = 
tray-maxsize =  16
tray-background = ${colors.background}

font-0 = SourceCodeProMedium:size=8;0
font-1 = FontAwesome5Free:style=Solid:pixelsize=8
font-2 = SourceCodeProMedium:weight=bold:size=8;0
font-3 = FontAwesome5Brands:style=Solid:pixelsize=8

[module/xwindow]
type = internal/xwindow
label = %title%
label-maxlen = 30

[module/i3]
type = internal/i3
enable-click = false
enable-scroll = false
strip-wsnumbers = true

ws-icon-0 = 1:; 
ws-icon-1 = 2:; 
ws-icon-2 = 3:; 
ws-icon-3 = 4:;  
ws-icon-default = 

label-focused-padding = 1
label-focused-background = ${colors.gray}

label-unfocused-padding = 1
label-visible-padding = 1

label-urgent-padding = 1
label-urgent-foreground = ${colors.red}

[module/wlan]
type = internal/network
interface = wlan0
interval = 3.0

format-connected-padding = 1
format-disconnected-padding = 1

format-connected = <label-connected>
format-connected-underline = ${colors.white}
format-disconnected-underline = ${colors.gray}

label-connected = %essid%
label-disconnected = 
label-disconnected-foreground = ${colors.gray}

[module/eth]
type = internal/network
interface = enp0s31f6
interval = 3.0

format-connected-padding = 1
format-disconnected-padding = 1

format-connected-underline = ${colors.white}
format-disconnected-underline = ${colors.gray}

label-connected =  
label-disconnected = 
label-disconnected-foreground = ${colors.gray}

[module/date]
type = internal/date
date =  %m/%d/%y %H:%M 
interval = 5
format-underline = ${colors.white}
format-foreground = ${colors.white}
format-padding = 1

[module/volume]
type = internal/alsa

format-volume = <label-volume>

label-volume =  %percentage%
label-volume-foreground = ${colors.white}

label-muted = 
label-muted-foreground = ${colors.gray}

[module/battery]
type = internal/battery
battery = BAT0
adapter = AC
time-format = %H:%M

format-charging = <animation-charging> <label-charging>
format-charging-underline = ${colors.green}
format-charging-padding = 1

label-charging = %time%
label-discharging = %time%
label-full =   

format-discharging = <ramp-capacity> <label-discharging>
format-discharging-underline = ${colors.yellow}
format-discharging-padding = 1

format-full-underline = ${self.format-charging-underline}
format-full-overline = ${self.format-charging-underline}
format-full-padding = 1

ramp-capacity-0 = 
ramp-capacity-1 = 
ramp-capacity-2 = 
ramp-capacity-3 = 
ramp-capacity-4 = 

animation-charging-0 = 
animation-charging-1 = 
animation-charging-2 = 
animation-charging-3 = 
animation-charging-4 = 
animation-charging-foreground = ${colors.white}
animation-charging-framerate = 500

; vim:ft=dosini

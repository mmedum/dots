[global]
font = Source Code Pro Medium 10
allow_markup = yes
format = "<b>%s</b>\n%b"
sort = yes
indicate_hidden = yes
alignment = center
bounce_freq = 0
show_age_threshold = 300
word_wrap = yes
ignore_newline = no
geometry = "250x50-40+40"
shrink = no
transparency = 0
idle_threshold = 120
monitor = 0
 will be ignored.
follow = mouse
sticky_history = yes
history_length = 20
show_indicators = no
line_height = 3
separator_height = 2
padding = 20
horizontal_padding = 15
separator_color = auto
startup_notification = false
icon_position = off

[frame]
width = 1
color = "#ebdbb2"

[shortcuts]
close = ctrl+space
close_all = ctrl+shift+space
history = ctrl+grave
context = ctrl+shift+period

[urgency_low]
foreground = "#ebdbb2"
background = "#32302f"
timeout = 3

[urgency_normal]
foreground = "#ebdbb2"
background = "#32302f"
timeout = 3

[urgency_critical]
foreground = "#ebdbb2"
background = "#32302f"
timeout = 3

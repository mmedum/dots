;:set syn=dosini

[global/wm]
margin-top = 5
margin-bottom = 5


[colors]
white = #d1d1d1
gray = #585858
black = #090909
red = #c795ae
blue = #95aec7
yellow = #c7ae95
green = #aec795


[bar/Bar]
bottom = false
monitor = eDP1
dock = false
wm-restack = i3
width = 100%
height = 24

enable-ipc = true

padding-left = 0
padding-right = 1

module-margin-right = 1

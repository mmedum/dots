modules-left = i3 xwindow
modules-center = date
modules-right = volume eth wlan battery

background = #99090909
foreground = ${colors.white}

underline-size = 2
underline-color = ${colors.white}

tray-detached = false
tray-position = right
tray-offset-x = 
tray-maxsize =  16
tray-padding = 

font-0 = SourceCodeProMedium:size=8;0
font-1 = FontAwesome:size=10;0
font-2 = SourceCodeProMedium:weight=bold:size=8;0
font-3 = FontAwesome:size=10;0

[module/xwindow]
type = internal/xwindow
label = %title%
label-maxlen = 30

[module/filesystem]
type = internal/fs
interval = 25

mount-0 = /


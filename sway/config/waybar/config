{
    "layer": "top",
    "position": "top",
    // If height property would be not present, it'd be calculated dynamically
    //"width" : 10,

    "modules-left": [
        "sway/workspaces",
        "sway/window"
    ],

    "modules-center": [     
        "clock",
    ],

    "modules-right": [
        "pulseaudio",
        "battery",
        "network",
        "idle_inhibitor",
        "tray",
    ],

    // Modules
    "idle_inhibitor": {
        "format": "{icon} ",
        "format-icons":{
            "activated": "яБо",
            "deactivated": "яБ░"
        }
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% яЧз",
        "format-plugged": "{capacity}% яЗж",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"],
        "on-click": ""
    },

    "clock": {
        "interval": 60,
        "format": "яБ│ {:%A %d %b яАЧ %H:%M}",
        "tooltip-format": "",
        "on-click": ""
    },

    "network": {
        "interval": 5,
        "format-wifi": "яЗл {essid}", // Icon: wifi
        "format-ethernet": "яГм  {ifname}: {ipaddr}/{cidr}", // Icon: ethernet
        "format-disconnected": "тЪа  Disconnected",
        "tooltip-format": "{ifname}: {ipaddr}",
        "on-click": "alacritty -e 'nmtui'",
    },
    "network#vpn": {
        "interface": "tun0",
        "format": "яАТ  {essid}",
        "format-disconnected": "тЪа  Disconnected",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",          
    },

    "sway/mode": {
        "format": "{}",
        "tooltip": false
    },

    "sway/window": {
        "format": "{}",
        "max-length": 120
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "disable-markup": false,
        "disable-click": true, 
        "all-outputs": false,
        "format": "{icon}",
        "format-icons": {
            "1": "яДб",
            "2": "яДа",
            "3": "яЙи",
            "4": "яЖШ",
            "5": "яДа",
            "6": "яДа",
            "7": "яДа",
            "8": "яДа",
            "9": "яДа",
            "10": "яДа",
            "urgent": "яБк",
            "focused": "яЖТ",
            "default": "яДа"
        }
    },

    "pulseaudio": {
        "format": "{icon} {volume}% {format_source}",
        "format-bluetooth": "{icon} яКФ {volume}",
        "format-bluetooth-muted": "яЪй {icon} яКФ",
        "format-muted": "якА {format_source}",
        "format-source": "яД░",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яЯК",
            "hands-free": "яЦР",
            "headset": " яЯН ",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАз", "яАи"]
        },
        "scroll-step": 2,
        "on-click": "pavucontrol",
        "on-scroll-up": "pamixer -ui 2",
        "on-scroll-down": "pamixer -ud 2",
    },

    "backlight#icon": {
        "format": "{icon}",
        "format-icons": ["яЖЕ"],
        "on-scroll-down": "brightnessctl -c backlight set 1%-",
        "on-scroll-up": "brightnessctl -c backlight set +1%"
    },

    "backlight#value" :{
        "format": "{percent}%",
        "on-scroll-down": "brightnessctl -c backlight set 1%-",
        "on-scroll-up": "brightnessctl -c backlight set +1%"
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
}

{
  "position": "bottom", // Waybar position (top|bottom|left|right)
  "modules-left": ["sway/workspaces", "sway/window", "sway/mode"],
  "modules-right": ["pulseaudio", "backlight", "battery", "network", "clock"],

  "clock": {
    "tooltip-format": "{:%B %Y}",
    "format": "{:%b %d(%H:%M) яЧ┤}"
  },

  "backlight": {
    "format": "{percent}% {icon}",
    "format-icons": ["юПг", "юПв", "юПб", "юПа", "юПЯ", "юПЮ", "юПЭ", "юПЬ", "юПЫ", "юПЪ", "юПЩ", "юПШ", "юПЧ", "юПЦ", "юПХ"]
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% яЧз",
    "format-plugged": "{capacity}% яЗж",
    "format-alt": "{time} {icon}",
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
  },

  "pulseaudio": {
    "format": "{volume}% {icon} {format_source}",
    "format-bluetooth": "{volume}% {icon} яКФ {format_source}",
    "format-bluetooth-muted": "якА {icon} яКФ {format_source}",
    "format-muted": "якА {format_source}",
    "format-source": "{volume}% яД░",
    "format-source-muted": "яД▒",
    "format-icons": {
      "headphone": "яАе",
      "hands-free": "янЛ",
      "headset": " яЯН ",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": ["яАж", "яАз", "яАи"]
    },
    "on-click": "pavucontrol",
  },

  "network": {
    "format": "{ifname}",
    "format-wifi": "{essid} яЗл",
    "format-ethernet": "{ipaddr}/{cidr} яЮЦ",
    "format-disconnected": "Disconnected якй", //An empty format will hide the module.
    "tooltip-format": "{ifname} via {gwaddr} яЮЦ",
    "tooltip-format-wifi": "{ipaddr} ({signalStrength}%) яЗл",
    "tooltip-format-ethernet": "{ifname} яГБ",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "alacritty -e 'nmtui'",
  },

  "sway/workspaces": {
    "disable-scroll": true
  }
}

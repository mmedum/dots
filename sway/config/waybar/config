{
    "layer": "top",
    "position": "top",
    // If height property would be not present, it'd be calculated dynamically
    "width" : 10,

    "modules-left": [
        "custom/launcher",
        "sway/workspaces",
        "sway/window"
    ],

    "modules-center": [     
        "clock",
    ],

    "modules-right": [
        "pulseaudio",
        "battery",
        "network",
        "idle_inhibitor",
        "tray",
        "custom/power",
    ],

    // Modules
    "idle_inhibitor": {
        "format": "{icon} ",
        "format-icons":{
            "activated": "’ü«",
            "deactivated": "’ü░"
        }
    },

    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ’Ś¦",
        "format-plugged": "{capacity}% ’ć”",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]
    },

    "clock": {
        "interval": 60,
        "format": "’ü│ {:%A %d %b ’ĆŚ %H:%M}",
        "tooltip-format": ""
    },

    "network": {
        "interval": 5,
        "format-wifi": "’ć½ {essid} ({signalStrength}%)", // Icon: wifi
        "format-ethernet": "’ā¼  {ifname}: {ipaddr}/{cidr}", // Icon: ethernet
        "format-disconnected": "ŌÜĀ  Disconnected",
        "tooltip-format": "{ifname}: {ipaddr}",
        "on-click": "alacritty -e 'nmtui'",
    },
    "network#vpn": {
        "interface": "tun0",
        "format": "’ĆÆ  {essid} ({signalStrength}%)",
        "format-disconnected": "ŌÜĀ  Disconnected",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",          
    },

    "sway/mode": {
        "format": "{}",
        "tooltip": false
    },

    "sway/window": {
        "format": "{}",
        "max-length": 120
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "disable-markup" : false,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "’äĪ",
            "2": "’äĀ",
            "3": "’ē®",
            "4": "’åś",
            "5": "’äĀ",
            "6": "’äĀ",
            "7": "’äĀ",
            "8": "’äĀ",
            "9": "’äĀ",
            "10": "’äĀ",
        }
    },

    "pulseaudio": {
        "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon} ’Ŗö {format_source}",
        "format-bluetooth-muted": "’Ü® {icon} ’Ŗö {format_source}",
        "format-muted": "’¬Ć {format_source}",
        "format-source": "{volume}% ’ä░",
        "format-source-muted": "’ä▒",
        "format-icons": {
            "headphone": "’¤Ŗ",
            "hands-free": "’Łŗ",
            "headset": " ’¤Ź ",
            "phone": "’éĢ",
            "portable": "’éĢ",
            "car": "’å╣",
            "default": ["’Ć¦"]
        },
        "on-click": "pavucontrol",
        "on-scroll-up": "pamixer -ui 2",
        "on-scroll-down": "pamixer -ud 2",
    },

    "backlight#icon": {
        "format": "{icon}",
        "format-icons": ["’åģ"],
        "on-scroll-down": "brightnessctl -c backlight set 1%-",
        "on-scroll-up": "brightnessctl -c backlight set +1%"
    },

    "backlight#value" :{
        "format": "{percent}%",
        "on-scroll-down": "brightnessctl -c backlight set 1%-",
        "on-scroll-up": "brightnessctl -c backlight set +1%"
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    "custom/launcher": {
        "format":"’īā ",
        "on-click": "exec wofi -c ~/.config/wofi/config -I",
        "tooltip": false,
    },

    "custom/power": {
        "format":"ŌÅ╗",
        "on-click": "exec ~/.config/waybar/scripts/power-menu.sh",
        "tooltip": false,
    },
}

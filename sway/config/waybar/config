{
    "layer": "top",
    "position": "top",

    "modules-left": [
        "sway/workspaces",
        "sway/window"
    ],

    "modules-center": [     
        "clock",
    ],

    "modules-right": [
        "pulseaudio",
        "battery",
        "network",
        "tray",
    ],

    // Modules
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ",
        "format-plugged": "{capacity}% ",
        "format-icons": ["", "", "", "", ""],
        "on-click": ""
    },

    "clock": {
        "interval": 60,
        "format": " {:%A %d %b  %H:%M}",
        "tooltip-format": "",
        "on-click": ""
    },

    "network": {
        "interval": 5,
        "format-wifi": " {essid}", // Icon: wifi
        "format-ethernet": "  {ifname}: {ipaddr}/{cidr}", // Icon: ethernet
        "format-disconnected": "⚠  Disconnected",
        "tooltip-format": "{ifname}: {ipaddr}",
        "on-click": "alacritty -e 'nmtui'",
    },
    "network#vpn": {
        "interface": "tun0",
        "format": "  {essid}",
        "format-disconnected": "⚠  Disconnected",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",          
    },

    "sway/window": {
        "format": "{}",
        "max-length": 120
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "disable-markup": false,
        "disable-click": true, 
        "all-outputs": false,
        "format": "{icon}",
        "format-icons": {
            "1": "",
            "2": "",
            "3": "",
            "urgent": "",
            "default": ""
        }
    },

    "pulseaudio": {
        "format": "{icon} {volume}% {format_source}",
        "format-bluetooth": "{icon}  {volume}",
        "format-bluetooth-muted": " {icon} ",
        "format-muted": "婢 {format_source}",
        "format-source": "",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "  ",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", ""]
        },
        "scroll-step": 2,
        "on-click": "pavucontrol",
        "on-scroll-up": "pamixer -ui 2",
        "on-scroll-down": "pamixer -ud 2",
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
}

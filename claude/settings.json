{
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/mark/.claude/statusline-command.sh",
    "refreshInterval": 10
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "local-plugins": {
      "source": {
        "source": "directory",
        "path": "/Users/mark/.claude/local-marketplace"
      }
    }
  },
  "effortLevel": "high",
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "ty-lsp@local-plugins": true
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(npm run test:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)"
    ]
  }
}
